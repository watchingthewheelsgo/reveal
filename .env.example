# =============================================================================
# Reveal 配置文件
# 复制为 .env 并填入实际值
# =============================================================================

# ---------------------------------------------------------------------------
# Telegram Bot
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# Comma-separated if multiple admins.
TELEGRAM_ADMIN_CHAT_ID=

# ---------------------------------------------------------------------------
# 飞书 Bot
# ---------------------------------------------------------------------------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Optional HTTP callback verification settings for /feishu/event.
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
# Set false if you use only HTTP callbacks instead of Feishu WebSocket.
FEISHU_ENABLE_WS=true
# Comma-separated if multiple admin chats.
FEISHU_ADMIN_CHAT_ID=

# ---------------------------------------------------------------------------
# 数据库
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/reveal.db
# Hosted Postgres/Supabase is also supported. Reveal normalizes plain
# postgresql:// URLs to postgresql+asyncpg:// and defaults SSL to required.
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# On Render, prefer Supabase Session Pooler because the direct db.<ref> host is IPv6-only.
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_ECHO=false

# ---------------------------------------------------------------------------
# LLM (普通聊天/摘要/意图分类使用 DeepSeek OpenAI-compatible endpoint)
# ---------------------------------------------------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
MAX_TOKENS=32000
TEMPERATURE=0.7

# ---------------------------------------------------------------------------
# Finnhub (美股行情 + 新闻，免费注册: finnhub.io)
# ---------------------------------------------------------------------------
FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# ---------------------------------------------------------------------------
# 调度配置
# ---------------------------------------------------------------------------
SCHEDULER_TIMEZONE=America/New_York
DAILY_PICK_TIME=08:00
DAILY_BRIEFING_TIME=08:30
TWITTER_MONITOR_INTERVAL=3600
TWITTER_DIGEST_ENABLED=true
TWITTER_DIGEST_TIME=17:00
TWITTER_DIGEST_TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# 告警配置
# ---------------------------------------------------------------------------
ALERT_ENABLED=true
ALERT_INTERVAL_MINUTES=30
ALERT_PRICE_PCT=3.0
ALERT_VOLUME_RATIO=2.5

# SEC / FDA regulatory event alerts.
# SEC requires a descriptive User-Agent for automated EDGAR access.
REGULATORY_ALERT_ENABLED=true
REGULATORY_ALERT_INTERVAL_MINUTES=60
REGULATORY_ALERT_LOOKBACK_HOURS=24
SEC_USER_AGENT=Reveal/0.1 theheisensky@gmail.com
SEC_ALERT_FORMS=8-K,10-K,10-Q,S-1,F-1,SC 13D,SC 13G,4,424B,DEF 14A
FDA_ALERT_ENABLED=true
FDA_BASE_URL=https://api.fda.gov
FDA_ALERT_CATEGORIES=drug,device
FDA_ALERT_CLASSIFICATIONS=Class I,Class II
# Optional extra company/product keywords for FDA recall matching.
FDA_ALERT_KEYWORDS=

# ---------------------------------------------------------------------------
# Twitter/X 监控账号
# 支持逗号分隔: elonmusk,naval
# 也支持 JSON 数组: ["elonmusk","naval"]
# ---------------------------------------------------------------------------
TWITTER_ACCOUNTS=
TWITTER_AUTH_TOKENS=

# ---------------------------------------------------------------------------
# Deep research agent
# ---------------------------------------------------------------------------
# Reveal uses Claude Agent SDK as the research runtime. DeepSeek is connected
# through its Anthropic-compatible endpoint. If ANTHROPIC_AUTH_TOKEN is empty,
# DEEPSEEK_API_KEY is reused as the DeepSeek API key.
AGENT_RUNTIME=claude_sdk
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
AGENT_EFFORT=max
AGENT_MAX_TURNS=8
