# =============================================================================
# Reveal 配置文件
# 复制为 .env 并填入实际值
# =============================================================================

# ---------------------------------------------------------------------------
# Telegram Bot
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# Comma-separated if multiple admins.
TELEGRAM_ADMIN_CHAT_ID=

# ---------------------------------------------------------------------------
# 飞书 Bot
# ---------------------------------------------------------------------------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Optional HTTP callback verification settings for /feishu/event.
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
# Set false if you use only HTTP callbacks instead of Feishu WebSocket.
FEISHU_ENABLE_WS=true
# Comma-separated if multiple admin chats.
FEISHU_ADMIN_CHAT_ID=

# ---------------------------------------------------------------------------
# 数据库
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/reveal.db
DATABASE_ECHO=false

# ---------------------------------------------------------------------------
# LLM (普通聊天/摘要使用 OpenAI SDK 兼容格式，默认 DeepSeek)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
MAX_TOKENS=32000
TEMPERATURE=0.7

# ---------------------------------------------------------------------------
# Finnhub (美股行情 + 新闻，免费注册: finnhub.io)
# ---------------------------------------------------------------------------
FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# ---------------------------------------------------------------------------
# 调度配置
# ---------------------------------------------------------------------------
SCHEDULER_TIMEZONE=US/Eastern
DAILY_PICK_TIME=08:00
DAILY_BRIEFING_TIME=08:30
TWITTER_MONITOR_INTERVAL=3600
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Twitter/X 监控账号
# 支持逗号分隔: elonmusk,naval
# 也支持 JSON 数组: ["elonmusk","naval"]
# ---------------------------------------------------------------------------
TWITTER_ACCOUNTS=

# ---------------------------------------------------------------------------
# Deep research agent
# ---------------------------------------------------------------------------
# Reveal uses Claude Agent SDK as the research runtime. Prefer the native
# ANTHROPIC_* names used by Claude Code / Agent SDK. If ANTHROPIC_AUTH_TOKEN
# is empty, CLAUDE_AGENT_AUTH_TOKEN is used; if that is empty, OPENAI_API_KEY
# is reused as the DeepSeek API key.
AGENT_RUNTIME=claude_sdk
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
CLAUDE_AGENT_BASE_URL=https://api.deepseek.com/anthropic
CLAUDE_AGENT_AUTH_TOKEN=
CLAUDE_AGENT_MODEL=deepseek-v4-pro[1m]
CLAUDE_AGENT_SMALL_MODEL=deepseek-v4-flash
CLAUDE_AGENT_EFFORT=max
CLAUDE_AGENT_MAX_TURNS=8
